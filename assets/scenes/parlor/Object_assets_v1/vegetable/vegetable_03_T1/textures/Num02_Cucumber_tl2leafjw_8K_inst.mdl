mdl 1.6;

import ::math::*;
import ::state::*;
import ::tex::*;
import ::anno::*;
using OmniUe4Function import *;
using OmniUe4Base import *;

export annotation sampler_color();
export annotation sampler_normal();
export annotation sampler_grayscale();
export annotation sampler_alpha();
export annotation sampler_masks();
export annotation sampler_distancefield();
export annotation dither_masked_off();
export annotation world_space_normal();

export material Num02_Cucumber_tl2leafjw_8K_inst(
	float NormalIntensity = 0.0
	[[
		anno::display_name("Normal Intensity"),
		anno::ui_order(32),
		anno::in_group("Material Settings")
	]],
	float Tiling = 1.0
	[[
		anno::display_name("Tiling"),
		anno::ui_order(32),
		anno::in_group("Material Settings")
	]],
	float CropX = 1.0
	[[
		anno::display_name("Crop X"),
		anno::ui_order(32),
		anno::in_group("Material Settings")
	]],
	float CropY = 1.0
	[[
		anno::display_name("Crop Y"),
		anno::ui_order(32),
		anno::in_group("Material Settings")
	]],
	uniform texture_2d Normal = texture_2d("./Textures/DefaultNormal.png",::tex::gamma_linear)
	[[
		anno::display_name("Normal"),
		anno::ui_order(32),
		anno::in_group("Input Textures"),
		sampler_normal()
	]],
	uniform texture_2d Albedo = texture_2d("./Textures/DefaultDiffuse.png",::tex::gamma_srgb)
	[[
		anno::display_name("Albedo"),
		anno::ui_order(32),
		anno::in_group("Input Textures"),
		sampler_color()
	]],
	float4 ColorOverlay = float4(0.5,0.5,0.5,1.0)
	[[
		anno::display_name("Color Overlay"),
		anno::ui_order(32),
		anno::in_group("Material Settings")
	]],
	float OverlayIntensity = 1.0
	[[
		anno::display_name("Overlay Intensity"),
		anno::ui_order(32),
		anno::in_group("Material Settings"),
		anno::soft_range(0.0, 1.5)
	]],
	uniform texture_2d Metallic = texture_2d("./Textures/DefaultWhiteGrid.png",::tex::gamma_srgb)
	[[
		anno::display_name("Metallic"),
		anno::ui_order(32),
		anno::in_group("Input Textures"),
		sampler_color()
	]],
	float Metallic_sp = 0.0
	[[
		anno::display_name("Metallic"),
		anno::ui_order(32),
		anno::in_group("Material Settings")
	]],
	uniform texture_2d Roughness = texture_2d("./Textures/DefaultWhiteGrid.png",::tex::gamma_srgb)
	[[
		anno::display_name("Roughness"),
		anno::ui_order(32),
		anno::in_group("Input Textures"),
		sampler_color()
	]],
	float RoughnessIntensity = 1.0
	[[
		anno::display_name("Roughness Intensity"),
		anno::ui_order(32),
		anno::in_group("Material Settings")
	]],
	int MaxTexCoordIndex = 3
	[[
		anno::hidden()
	]])
 = 
	let {
	float3 WorldPositionOffset_mdl = float3(0.0,0.0,0.0);
	float2 CustomizedUV0_mdl = float2(state::texture_coordinate(math::min(0,MaxTexCoordIndex)).x,1.0-state::texture_coordinate(math::min(0,MaxTexCoordIndex)).y);

	float2 Local0 = (CustomizedUV0_mdl * Tiling);
	float2 Local1 = (1.0 + float2(CropX,CropY));
	float2 Local2 = (Local0 + Local1);
	float4 Local3 = ::unpack_normal_map(tex::lookup_float4(Normal,float2(Local2.x,1.0-Local2.y),tex::wrap_repeat,tex::wrap_repeat));
	float3 Local4 = (float3(float2(NormalIntensity,NormalIntensity).x,float2(NormalIntensity,NormalIntensity).y,0.0) * float3(Local3.x,Local3.y,Local3.z));
	float3 Local5 = (Local4 + float3(Local3.x,Local3.y,Local3.z));

	float3 Normal_mdl = Local5;

	float4 Local6 = tex::lookup_float4(Albedo,float2(Local2.x,1.0-Local2.y),tex::wrap_repeat,tex::wrap_repeat);
	float3 Local7 = (1.0 - float3(Local6.x,Local6.y,Local6.z));
	float3 Local8 = (Local7 * 2.0);
	float3 Local9 = (1.0 - float3(ColorOverlay.x,ColorOverlay.y,ColorOverlay.z));
	float3 Local10 = (Local8 * Local9);
	float3 Local11 = (1.0 - Local10);
	float3 Local12 = (float3(Local6.x,Local6.y,Local6.z) * 2.0);
	float3 Local13 = (Local12 * float3(ColorOverlay.x,ColorOverlay.y,ColorOverlay.z));
	float Local14 = ((float3(Local6.x,Local6.y,Local6.z).x >= 0.5) ? Local11.x : Local13.x);
	float Local15 = ((float3(Local6.x,Local6.y,Local6.z).y >= 0.5) ? Local11.y : Local13.y);
	float Local16 = ((float3(Local6.x,Local6.y,Local6.z).z >= 0.5) ? Local11.z : Local13.z);
	float3 Local17 = math::lerp(float3(Local6.x,Local6.y,Local6.z),float3(float2(Local14,Local15).x,float2(Local14,Local15).y,Local16),OverlayIntensity);
	float4 Local18 = tex::lookup_float4(Metallic,float2(Local2.x,1.0-Local2.y),tex::wrap_repeat,tex::wrap_repeat);
	float Local19 = (Local18.x * Metallic_sp);
	float4 Local20 = tex::lookup_float4(Roughness,float2(Local2.x,1.0-Local2.y),tex::wrap_repeat,tex::wrap_repeat);
	float Local21 = (Local20.x * RoughnessIntensity);

	float3 EmissiveColor_mdl = float3(0.0,0.0,0.0);
	float OpacityMask_mdl = 1.0;
	float3 BaseColor_mdl = Local17;
	float Metallic_mdl = Local19;
	float Specular_mdl = 0.5;
	float Roughness_mdl = Local21;

	} in
		::OmniUe4Base(
			base_color: BaseColor_mdl,
			metallic: Metallic_mdl,
			roughness: Roughness_mdl,
			specular: Specular_mdl,
			normal: Normal_mdl,
			opacity: OpacityMask_mdl,
			emissive_color: EmissiveColor_mdl,
			displacement: WorldPositionOffset_mdl,
			two_sided: false);
